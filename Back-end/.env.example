# .env.example - Template pre .env konfiguráciu

# ============================================
# DATABASE - Supabase Cloud
# ============================================
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@YOUR_SUPABASE_HOST:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=sb_secret_YOUR_KEY_HERE
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# EMAIL (budúcnosť)
# ============================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password

# ============================================
# SERVER
# ============================================
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8081

# ============================================
# 3D MODELS - NERFSTUDIO
# ============================================
# Cesta k priečinku s projektami
# Musí existovať a obsahovať štruktúru: user_id/project_id/images
PROJECTS_PATH=D:\GitHub\3D-rekon-trukcia-a-mapovanie-interi-rov-z-obrazov-ch-inform-ci-\Back-end\projects

# Nerfstudio konfigurácia
NERFSTUDIO_METHOD=nerfacto
NERFSTUDIO_ITERATIONS=30000
NERFSTUDIO_GPU=true

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=nerfstudio_training.log
